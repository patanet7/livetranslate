# Orchestration Service - Local Development Configuration
# ========================================================

# Server
HOST=0.0.0.0
PORT=3000
ENVIRONMENT=development
DEBUG=false

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/livetranslate

# Redis
REDIS_URL=redis://localhost:6379/0

# Service URLs
WHISPER_SERVICE_URL=http://localhost:5001
TRANSLATION_SERVICE_URL=http://localhost:5003

# Bot Management (disabled for local dev)
BOT_ENABLE_DATABASE=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=dev

# Meeting Intelligence (direct Ollama)
INTELLIGENCE_DIRECT_LLM_ENABLED=true
INTELLIGENCE_DIRECT_LLM_BASE_URL=http://localhost:11434/v1
INTELLIGENCE_DIRECT_LLM_MODEL=qwen2.5:3b

# Fireflies (auto-connects to active meetings)
FIREFLIES_API_KEY=b1dc49d5-250a-4e1f-b61b-f990248c8c85

# ==========================================
# Fireflies Real-Time Enhancement Config
# ==========================================

# Fireflies Auto-Connect
FIREFLIES_AUTO_CONNECT=false
FIREFLIES_POLL_INTERVAL=30

# Display
DEFAULT_DISPLAY_MODE=both

# Persistence
MEETING_AUTO_SAVE=true
MEETING_DOWNLOAD_ON_COMPLETE=true
MEETING_DOWNLOAD_INSIGHTS=true

# Voice Commands (experimental)
VOICE_COMMANDS_ENABLED=false
VOICE_COMMAND_PREFIX=LiveTranslate

# Features
ENABLE_AUDIO_PROCESSING=true
ENABLE_TRANSLATION=true
